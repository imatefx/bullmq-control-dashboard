# Authentication (HTTP Basic Auth) — copy to .env and set real values.
# The server refuses to start unless ADMIN_USERNAME and ADMIN_PASSWORD are set.

# Admin: full access (manage connections, edit queues, job actions, import, export secrets)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Reader (optional): read-only access. Omit to disable the reader role.
READER_USERNAME=reader
READER_PASSWORD=change-me-too

# Optional
# PORT=3010
# CONFIG_PATH=./config/config.json
